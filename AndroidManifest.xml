<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.plantdetector">

    <uses-permission android:name="android.permission.CAMERA"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>

    <uses-feature android:name="android.hardware.camera.any" android:required="true"/>

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_check_circle"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_check_circle"
        android:supportsRtl="true"
        android:theme="@style/Theme.PlantDetector">

        <activity
            android:name=".ui.camera.MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.result.ResultActivity"
            android:exported="false"
            android:parentActivityName=".ui.camera.MainActivity"/>

        <activity
            android:name=".ui.history.HistoryActivity"
            android:exported="false"
            android:parentActivityName=".ui.camera.MainActivity"/>

    </application>

</manifest>
